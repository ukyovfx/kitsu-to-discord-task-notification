# ============================================================
# KitsuSync config template
# Copy to conf.toml and adjust the non-secret values.
# Secret values should stay in .env.
# ============================================================

tplPreset = "rich"
ignoreMessagesDaysOld = 5
silentUpdateDB = false
threads = 12
debug = false
log = true

[kitsu]
    hostname = "${KITSU_HOSTNAME}"
    email = "${KITSU_RUNTIME_EMAIL}"
    password = "${KITSU_RUNTIME_PASSWORD}"
    skipComments = false
    requestInterval = 1

[discord]
    embedsPerRequests = 10
    RequestsPerMinute = 50
    webhookURL = "${DISCORD_WEBHOOK_URL}"
    useThreads = false

    # Required for /bot/setup and /bot/admin channel operations.
    botToken = "${DISCORD_BOT_TOKEN}"
    guildID = "${DISCORD_GUILD_ID}"

# Optional project-level fallback routes.
#[[discord.productions]]
#    production = "ProjectA"
#    webhookURL = "https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME"

# Optional task-type routes.
#[[discord.taskTypeWebhooks]]
#    taskType = "Compositing"
#    webhookURL = "https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME"

#[[discord.taskTypeWebhooks]]
#    taskType = "Animation"
#    webhookURL = "https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME"

[mention]
    checkerStatuses = ["WFA"]
    artistStatuses = ["READY", "RETAKE", "DONE"]
    hereStatuses = []

[[mention.userMap]]
    kitsuName = "Taro Yamada"
    discordID = "123456789012345678"

[[mention.checkers]]
    taskType = "Animation"
    discordID = "345678901234567890"

[notification]
    notifyOnAssign = false

[googleDrive]
    url = "https://drive.google.com/drive/folders/YOUR_FOLDER_ID"

# ============================================================
# KitsuSync environment template
# Copy to .env.local (development) or .env.production (production).
# Never commit .env.local or .env.production to git.
# ============================================================

# Public Kitsu hostname used by the app and setup UI.
# Include the scheme and trailing slash.
KITSU_HOSTNAME=http://YOUR_KITSU_HOST/

# Runtime credential used by the poller after setup is complete.
# If you prefer guided setup, leave these blank at first boot and create
# the runtime bot account from /bot/setup after logging in.
KITSU_RUNTIME_EMAIL=
KITSU_RUNTIME_PASSWORD=

# Optional catch-all Discord webhook for unmatched notifications.
# Recommended even if you later split routes per project/task type.
DISCORD_WEBHOOK_URL=

# Discord bot credential used by /bot/setup and /bot/admin.
DISCORD_BOT_TOKEN=REPLACE_ME
DISCORD_GUILD_ID=REPLACE_ME

# ── deploy/docker-compose.yml (Traefik) only ────────────────────────────────
# Public hostname for Traefik routing and TLS certificate (no scheme, no slash).
# Example: kitsusync.example.com
PUBLIC_HOST=kitsusync.example.com
# Container name and image name prefix used by the deploy compose file.
ALIAS=kitsusync

# FileBrowser debug profile credentials.
# Used only when you explicitly run:
#   docker compose --profile debug up -d editor
# Generate a strong random password before use:
#   openssl rand -base64 20
# Then set FB_USERNAME and FB_PASSWORD in your .env.local / .env.production.
# Do NOT leave FB_PASSWORD blank — FileBrowser may start without auth if unset.
FB_USERNAME=admin
# FB_PASSWORD=  ← uncomment and set a generated value before starting

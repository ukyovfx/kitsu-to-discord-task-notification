# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Output of the go coverage tool
*.out

# Dependency directories
# vendor/

# Visual Studio Code
.vscode

# App
/conf.toml
tests.bat
/tools
/*.db
/release
/release/*.db
/vendor
/dump
/logs/*
*.zip

# Environment / secrets - never commit
.env
.env.local
.env.production
.env.development
.env.*.local
.envrc

# Runtime data - never commit
/data/
/data/*.db
/data/sqlite.db
/data/filebrowser.db
*.sqlite
*.sqlite3
*.db-shm
*.db-wal

# Deployment sample data - never commit
/deploy/.env
/deploy/data/
/deploy/*.env

# Presentation artifacts created during release prep
/screenshots/*.png
/screenshots/*.jpg
/screenshots/*.jpeg

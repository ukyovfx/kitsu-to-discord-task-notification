# =====================================================================
# Kitsu × Discord Notification — secret values
# =====================================================================
# 1. Copy this file to ".env" in the same directory
#      cp .env.example .env
# 2. Fill in the real values below
# 3. Keep .env out of git (already in .gitignore)
# =====================================================================

# Kitsu admin password used by the bot to authenticate against the API.
# Same password as the one you log into Kitsu's web UI with.
KITSU_PASSWORD=changeme

# Discord webhook URL for the channel that should receive task notifications.
# Get this from your Discord channel settings → Integrations → Webhooks.
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME/REPLACE_ME

# FileBrowser (port 8080) admin credentials.
# Used only on first boot to seed the FileBrowser DB.
FB_USERNAME=admin
FB_PASSWORD=changeme-please-12chars
